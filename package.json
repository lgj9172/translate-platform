{
  "name": "translate-platform",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "pnpm --filter @translate/web dev",
    "dev:api": "pnpm --filter @translate/api start:dev",
    "build:web": "pnpm --filter @translate/web build",
    "build:api": "pnpm --filter @translate/api build"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "5.8.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2"
    },
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ]
  }
}
