# ──────────────────────────────────────────────────────────────
# 환경변수 예시 파일 — 실제 값을 채워 각 환경 파일로 복사하세요
#
# 파일 우선순위 (높을수록 먼저 적용):
#   1. .env.local          ← 내 로컬 (git 제외)
#   2. .env.development    ← 개발 서버 (git 제외)
#   3. .env.production     ← 프로덕션 (git 제외, CI 주입 권장)
#
# NODE_ENV 는 package.json 스크립트가 자동으로 주입합니다:
#   pnpm dev            → NODE_ENV=development → .env.local 우선 로드
#   pnpm start:prod     → NODE_ENV=production  → .env.production 로드
# ──────────────────────────────────────────────────────────────

# Supabase
# https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Database
# https://supabase.com/dashboard/project/<ref>/settings/database
# Transaction pooler — 일반 쿼리용, 포트 6543
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Session pooler — 마이그레이션 전용 (DDL 지원), 포트 5432
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Server
PORT=3001
